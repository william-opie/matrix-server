server {
  listen 80;
  resolver 127.0.0.11 valid=30s ipv6=off;

  set $element_upstream http://matrix-element:80;
  set $synapse_upstream http://matrix-synapse:8008;

  location / {
    proxy_pass $element_upstream$request_uri;
    proxy_set_header Host $host;
  }

  location /_matrix/ {
    proxy_pass $synapse_upstream$request_uri;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  }

  location /_synapse/client/ {
    proxy_pass $synapse_upstream$request_uri;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  }

  location = /.well-known/matrix/client {
    default_type application/json;
    add_header Access-Control-Allow-Origin "*" always;
    add_header Access-Control-Allow-Methods "GET, OPTIONS" always;
    add_header Access-Control-Allow-Headers "X-Requested-With, Content-Type, Authorization" always;
    return 200 '{"m.homeserver":{"base_url":"$PUBLIC_BASEURL"},"org.matrix.msc4143.rtc_foci":[{"type":"livekit","livekit_service_url":"$MATRIX_RTC_LIVEKIT_SERVICE_URL"}]}';
  }

  location = /.well-known/matrix/server {
    default_type application/json;
    add_header Access-Control-Allow-Origin "*" always;
    return 200 '{"m.server":"$MATRIX_SERVER_NAME:443"}';
  }

  location /.well-known/matrix/ {
    return 404;
  }
}
